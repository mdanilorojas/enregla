# EnRegla Environment Variables
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# =============================================================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# UI VERSION (REQUIRED)
# =============================================================================
# Options: v1 | v2
# v2 = New design system with Manrope typography (recommended)
# v1 = Legacy UI (deprecated, will be removed)

VITE_UI_VERSION=v2

# =============================================================================
# DEMO MODE (OPTIONAL)
# =============================================================================
# VITE_DEMO_MODE=true  -> bypassa el login real y usa la empresa demo
#   (50707999-f033-41c4-91c9-989966311972) sin autenticarse. Útil para
#   demos públicas y desarrollo local sin OAuth.
# VITE_DEMO_MODE=false (o sin definir) -> login real con Google requerido.
#
# PRODUCCIÓN (app.enregla.ec): debe quedar SIN definir o en false.
# El arranque (main.tsx -> assertDemoModeNotInProduction) aborta si detecta
# VITE_DEMO_MODE=true en el host de producción.
VITE_DEMO_MODE=false

# =============================================================================
# DEVELOPMENT MODE (OPTIONAL)
# =============================================================================
# These are auto-detected by Vite, but can be overridden

# NODE_ENV=development  # Auto-set by Vite
# DEV=true              # Auto-set in dev mode

# =============================================================================
# SENTRY (OPTIONAL — ERROR TRACKING IN PRODUCTION)
# =============================================================================
# If unset, Sentry init is a no-op. Get DSN from sentry.io → Project Settings → Client Keys (DSN)

VITE_SENTRY_DSN=

# =============================================================================
# EMAIL SERVICE — NOTIFICACIONES (alertas de vencimiento + invitaciones)
# =============================================================================
# El envío de email NO ocurre en el cliente. Vive en las Edge Functions de
# Supabase (send-expiry-alerts, send-invitation), que se disparan por cron
# (pg_cron, diario 08:00 UTC). Estos secretos se configuran en:
#   Supabase Dashboard -> Edge Functions -> Manage secrets
# NO son VITE_* y NO van en este archivo del frontend; se listan aquí solo
# como referencia de lo que la plataforma necesita para enviar correos.
#
#   RESEND_API_KEY   (requerido) API key de https://resend.com
#   RESEND_FROM      (opcional)  remitente, e.g. "EnRegla <alertas@enregla.ec>"
#   APP_URL          (opcional)  base de links en los correos (default app.enregla.ec)
#   CRON_SECRET      (requerido) secreto que valida la invocación del cron
#
# Sin RESEND_API_KEY el cron corre (HTTP 200) pero no se entregan correos.

# =============================================================================
# CONTACTO COMERCIAL — WHATSAPP (OPTIONAL)
# =============================================================================
# Número en formato E.164 sin "+" (e.g. 593987654321) y formato visible para UI.
# Si están vacíos, el botón "Contratar por WhatsApp" se deshabilita.

VITE_WHATSAPP_NUMBER=
VITE_WHATSAPP_DISPLAY=

# =============================================================================
# SOPORTE Y STATUS PAGE (OPTIONAL)
# =============================================================================
# Email mostrado en footer/legales y URL pública del status page (BetterStack,
# Statuspage, etc). Si VITE_STATUS_URL queda vacío, no se muestra el link.

VITE_SUPPORT_EMAIL=soporte@enregla.ec
VITE_STATUS_URL=

# =============================================================================
# NOTES
# =============================================================================
# - All VITE_* variables are exposed to the client (browser)
# - DO NOT put secrets in VITE_* variables
# - Backend secrets should go in Supabase Edge Functions env vars
# - This file is tracked in git, .env.local is gitignored
# - Never commit .env.local to version control
