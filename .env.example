# EnRegla Environment Variables
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# =============================================================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# UI VERSION (REQUIRED)
# =============================================================================
# Options: v1 | v2
# v2 = New design system with Manrope typography (recommended)
# v1 = Legacy UI (deprecated, will be removed)

VITE_UI_VERSION=v2

# =============================================================================
# FEATURE FLAGS (OPTIONAL)
# =============================================================================
# Enable/disable features for gradual rollout

# Public Links: QR codes for inspectors (default: true)
VITE_ENABLE_PUBLIC_LINKS=true

# Google OAuth: Enable Google sign-in (default: true if Supabase configured)
VITE_ENABLE_GOOGLE_AUTH=true

# Network Map: Visual relationship graph (default: true)
VITE_ENABLE_NETWORK_MAP=true

# =============================================================================
# DEVELOPMENT MODE (OPTIONAL)
# =============================================================================
# These are auto-detected by Vite, but can be overridden

# NODE_ENV=development  # Auto-set by Vite
# DEV=true              # Auto-set in dev mode

# =============================================================================
# ANALYTICS (OPTIONAL - Future)
# =============================================================================
# Uncomment when analytics are implemented

# VITE_ANALYTICS_ID=
# VITE_SENTRY_DSN=

# =============================================================================
# EMAIL SERVICE (OPTIONAL - Phase 3)
# =============================================================================
# For email notifications (alerts, invites)

# VITE_EMAIL_PROVIDER=resend
# VITE_RESEND_API_KEY=

# =============================================================================
# NOTES
# =============================================================================
# - All VITE_* variables are exposed to the client (browser)
# - DO NOT put secrets in VITE_* variables
# - Backend secrets should go in Supabase Edge Functions env vars
# - This file is tracked in git, .env.local is gitignored
# - Never commit .env.local to version control
